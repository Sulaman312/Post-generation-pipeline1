CLIENTS_DATA_DIR=clients
API_PORT=8001
UI_PORT=3001
REACT_APP_PROJECT_MODE=social

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
FIGMA_ACCESS_TOKEN=

MONGODB_URI=
MONGODB_DB=post_generation_pipeline

# App login (users + sessions stored in MongoDB)
AUTH_ENABLED=1
AUTH_SECRET_KEY=change-me-in-production
AUTH_SESSION_DAYS=7
# Koyeb/HTTPS: secure session cookie is auto-detected from X-Forwarded-Proto; set explicitly if needed:
# AUTH_COOKIE_SECURE=1

# Image export — fit preserves full width on portrait frames (Instagram)
IMAGE_EXPORT_RESIZE_MODE=fit

# Auto-publish scheduled posts (checks every 5 minutes while API is running)
SCHEDULE_PUBLISH_ENABLED=1
SCHEDULE_PUBLISH_POLL_SECONDS=300

# Publishing environment — test (default) or live
PUBLISH_ENV=test

# Meta Graph — Facebook Page + Instagram publishing (test)
META_APP_ID=
META_APP_SECRET=
# OAuth callback URL — e.g. http://localhost:8001/auth/meta/callback
META_REDIRECT_URI=
META_USER_ACCESS_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# LinkedIn — Community Management API publishing (test)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_ACCESS_TOKEN=
# LinkedIn company Page organization URN or numeric id
LINKEDIN_ORG_URN=

# Meta / LinkedIn live credentials — per workspace in this .env (and on Koyeb).
# Pattern: META_LIVE_<WORKSPACE>_* and LINKEDIN_LIVE_<WORKSPACE>_*
# <WORKSPACE> = uppercased workspace id (non-alphanumeric → _). Example: Simonetti → SIMONETTI
#
# META_LIVE_SIMONETTI_PAGE_ACCESS_TOKEN=
# META_LIVE_SIMONETTI_PAGE_ID=
# META_LIVE_SIMONETTI_IG_USER_ID=
# LINKEDIN_LIVE_SIMONETTI_ACCESS_TOKEN=
# LINKEDIN_LIVE_SIMONETTI_ORG_URN=
# LINKEDIN_LIVE_SIMONETTI_PERSON_URN=
#
# Optional legacy global live fallback (no workspace suffix):
# META_LIVE_PAGE_ACCESS_TOKEN=
# META_LIVE_PAGE_ID=
# META_LIVE_IG_USER_ID=
# LINKEDIN_LIVE_ACCESS_TOKEN=
# LINKEDIN_LIVE_ORG_URN=
# LINKEDIN_LIVE_PERSON_URN=